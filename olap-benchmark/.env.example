# OLAP Benchmark Sandbox — Environment Variables
# Copy this file to .env and fill in your values
# Add secrets to Replit Secrets panel (not this file!)

# ---- Postgres (auto-configured from Replit DB) ----
# Leave blank to use Replit's built-in Postgres
POSTGRES_DB=olap_benchmark
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ---- Google BigQuery (optional — costs ~$8) ----
# Add GCP_PROJECT_ID and GCP_CREDENTIALS to Replit Secrets
# GCP_PROJECT_ID=your-gcp-project-id
# GCP_CREDENTIALS=<paste entire JSON service account key>
# GCP_DATASET=olap_benchmark
# GCS_BUCKET=your-bucket-name

# ---- Databricks (optional — costs ~$10) ----
# Add DATABRICKS_* to Replit Secrets
# DATABRICKS_HOST=https://your-workspace.azuredatabricks.net
# DATABRICKS_TOKEN=your-token
# DATABRICKS_CLUSTER_ID=your-cluster-id
# DATABRICKS_CATALOG=hive_metastore
# DATABRICKS_SCHEMA=olap_benchmark
